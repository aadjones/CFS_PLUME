# 26 "../../src/Eigen/Eigen/src/IterativeLinearSolvers/ConjugateGradient.h"
template<typename MatrixType, typename Rhs, typename Dest, typename Preconditioner>
__attribute__((noinline))
void conjugate_gradient(const MatrixType& mat, const Rhs& rhs, Dest& x,
                        const Preconditioner& precond, int& iters,
                        typename Dest::RealScalar& tol_error)
{
  using std::sqrt;
  using std::abs;
  typedef typename Dest::RealScalar RealScalar;
  typedef typename Dest::Scalar Scalar;
  typedef Matrix<Scalar,Dynamic,1> VectorType;

  RealScalar tol = tol_error;
  int maxIters = iters;

  int n = mat.cols();

  VectorType residual = rhs - mat * x;
  VectorType p(n);

  p = precond.solve(residual);

  VectorType z(n), tmp(n);
  RealScalar absNew = internal::real(residual.dot(p));
  RealScalar rhsNorm2 = rhs.squaredNorm();
  RealScalar residualNorm2 = 0;
  RealScalar threshold = tol*tol*rhsNorm2;
  int i = 0;
  while(i < maxIters)
  {
    tmp.noalias() = mat * p;

    Scalar alpha = absNew / p.dot(tmp);
    x += alpha * p;
    residual -= alpha * tmp;

    residualNorm2 = residual.squaredNorm();
    if(residualNorm2 < threshold)
      break;

    z = precond.solve(residual);

    RealScalar absOld = absNew;
    absNew = internal::real(residual.dot(z));
    RealScalar beta = absNew / absOld;
    p = z + beta * p;
    i++;
  }
  tol_error = sqrt(residualNorm2 / rhsNorm2);
  iters = i;
}

}

