# 353 "../../src/Eigen/Eigen/src/Eigenvalues/Tridiagonalization.h" 3 4
 ) : (void)0)
# 353 "../../src/Eigen/Eigen/src/Eigenvalues/Tridiagonalization.h"
                                          ;

  for (Index i = 0; i<n-1; ++i)
  {
    Index remainingSize = n-i-1;
    RealScalar beta;
    Scalar h;
    matA.col(i).tail(remainingSize).makeHouseholderInPlace(h, beta);



    matA.col(i).coeffRef(i+1) = 1;

