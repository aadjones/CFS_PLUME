inline typename internal::traits<Derived>::Scalar MatrixBase<Derived>::determinant() const
{
  
# 94 "../../src/Eigen/Eigen/src/LU/Determinant.h" 3 4
 (__builtin_expect(!(
# 94 "../../src/Eigen/Eigen/src/LU/Determinant.h"
 rows() == cols()
