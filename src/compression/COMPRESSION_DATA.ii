# 2 "COMPRESSION_DATA.cpp" 2


COMPRESSION_DATA::COMPRESSION_DATA() {}

COMPRESSION_DATA::COMPRESSION_DATA(const VEC3I& dims, int numCols, int nBits, double percent) :
  _dims(dims), _numCols(numCols), _nBits(nBits), _percent(percent)
{
  cout << "Initializing COMPRESSION_DATA:" << endl;
  cout << "  Dimensions: " << dims[0] << "x" << dims[1] << "x" << dims[2] << endl;
  cout << "  Number of columns: " << numCols << endl;
  cout << "  Bits per value: " << nBits << endl;
  cout << "  Compression percentage: " << percent << endl;


  _sListMatrix = MatrixXd();
  _gammaListMatrix = MatrixXd();
  _blockLengthsMatrix = MatrixXi();
  _blockIndicesMatrix = MatrixXi();

  cout << "  Initialized matrices for compression data" << endl;


  _dct_in = (double*)fftw_malloc(8 * 8 * 8 * sizeof(double));
  _dct_out = (double*)fftw_malloc(8 * 8 * 8 * sizeof(double));

  if (!_dct_in || !_dct_out) {
    cout << "Error: Failed to allocate FFTW buffers" << endl;
    exit(1);
  }

  cout << "  Allocated FFTW buffers" << endl;


  _dct_plan = fftw_plan_r2r_3d(8, 8, 8,
                               _dct_in, _dct_out,
                               FFTW_REDFT10, FFTW_REDFT10, FFTW_REDFT10,
                               (1U << 6));

  if (!_dct_plan) {
    cout << "Error: Failed to create FFTW plan" << endl;
    exit(1);
  }

  cout << "  Created FFTW plan" << endl;
}

COMPRESSION_DATA::~COMPRESSION_DATA()
{
  cout << "Cleaning up COMPRESSION_DATA resources..." << endl;

  if (_dct_plan) {
    fftw_destroy_plan(_dct_plan);
    cout << "  Destroyed FFTW plan" << endl;
  }

  if (_dct_in) {
    fftw_free(_dct_in);
    _dct_in = 
# 59 "COMPRESSION_DATA.cpp" 3 4
             __null
# 59 "COMPRESSION_DATA.cpp"
                 ;
    cout << "  Freed FFTW input buffer" << endl;
  }

  if (_dct_out) {
    fftw_free(_dct_out);
    _dct_out = 
# 65 "COMPRESSION_DATA.cpp" 3 4
              __null
# 65 "COMPRESSION_DATA.cpp"
                  ;
    cout << "  Freed FFTW output buffer" << endl;
  }


  cout << "  Cleaned up compression matrices" << endl;
}
# 148 "COMPRESSION_DATA.cpp"
void COMPRESSION_DATA::set_dampingArrayList() {
    TIMER functionTimer(__FUNCTION__);
    
# 150 "COMPRESSION_DATA.cpp" 3 4
   (__builtin_expect(!(
# 150 "COMPRESSION_DATA.cpp"
   _dampingArrayBuilt
# 150 "COMPRESSION_DATA.cpp" 3 4
   ), 0) ? __assert_rtn(__func__, "COMPRESSION_DATA.cpp", 150, 
# 150 "COMPRESSION_DATA.cpp"
   "_dampingArrayBuilt"
# 150 "COMPRESSION_DATA.cpp" 3 4
   ) : (void)0)
# 150 "COMPRESSION_DATA.cpp"
                             ;
    if (_dampingArrayListBuilt) { return; }

    puts("Inside set_dampingArrayList!");

    FIELD_3D dampingArray(_dampingArray);
    int totalNumber = 4 * _nBits + 1;
    _dampingArrayList.resize(totalNumber);
    cout << "total number: " << totalNumber << endl;
    for (int i = 0; i < totalNumber; i++) {
      double gamma = i / 4.0;
      dampingArray.toFastPower(gamma);
      _dampingArrayList[i] = dampingArray;
      dampingArray = _dampingArray;
    }
    _dampingArrayListBuilt = true;
    cout << "array list built: " << _dampingArrayListBuilt << endl;
}

void COMPRESSION_DATA::dct_setup(int direction) {
    const int xRes = 8;
    const int yRes = 8;
    const int zRes = 8;

    _dct_in = (double*) fftw_malloc(xRes * yRes * zRes * sizeof(double));
    _dct_out = (double*) fftw_malloc(xRes * yRes * zRes * sizeof(double));

    if (direction == 1) {
       _dct_plan = fftw_plan_r2r_3d(zRes, yRes, xRes, _dct_in, _dct_out,
           FFTW_REDFT10, FFTW_REDFT10, FFTW_REDFT10, (0U));
    }
    else {
       _dct_plan = fftw_plan_r2r_3d(zRes, yRes, xRes, _dct_in, _dct_out,
           FFTW_REDFT01, FFTW_REDFT01, FFTW_REDFT01, (0U));
    }
}

void COMPRESSION_DATA::dct_cleanup() {
   fftw_destroy_plan(_dct_plan);
   fftw_free(_dct_in);
   fftw_free(_dct_out);
   _dct_in = 
# 191 "COMPRESSION_DATA.cpp" 3 4
            __null
# 191 "COMPRESSION_DATA.cpp"
                ;
   _dct_out = 
# 192 "COMPRESSION_DATA.cpp" 3 4
             __null
# 192 "COMPRESSION_DATA.cpp"
                 ;
   fftw_cleanup();
}
