# 350 "../../src/Eigen/Eigen/src/Cholesky/LDLT.h" 3 4
   ) : (void)0)
# 350 "../../src/Eigen/Eigen/src/Cholesky/LDLT.h"
                                                     ;

    RealScalar alpha = 1;


