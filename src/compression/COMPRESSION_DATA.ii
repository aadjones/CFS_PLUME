    distance = 0;
    index = 0;
    heapIndex = 0;
  };

  double distance;
  int index;
  int heapIndex;
};


class MIN_HEAP
{
public:

 MIN_HEAP();
 virtual ~MIN_HEAP();


  void insert(HEAP_ENTRY& cell);

  void decreaseKey(int toChange, double newKey);
  HEAP_ENTRY popMin();
  HEAP_ENTRY heapMin();
