   (options&~(EigVecMask|GenEigMask))==0 && (options&EigVecMask)!=EigVecMask && "invalid option parameter"
# 545 "../../src/Eigen/Eigen/src/Eigenvalues/SelfAdjointEigenSolver.h" 3 4
