template<typename MatrixType>
void HessenbergDecomposition<MatrixType>::_compute(MatrixType& matA, CoeffVectorType& hCoeffs, VectorType& temp)
{
  
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h" 3 4
 (__builtin_expect(!(
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h"
 matA.rows()==matA.cols()
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h" 3 4
 ), 0) ? __assert_rtn(__func__, "HessenbergDecomposition.h", 294, 
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h"
 "matA.rows()==matA.cols()"
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h" 3 4
 ) : (void)0)
# 294 "../../src/Eigen/Eigen/src/Eigenvalues/./HessenbergDecomposition.h"
                                 ;
  Index n = matA.rows();
  temp.resize(n);
  for (Index i = 0; i<n-1; ++i)
  {

    Index remainingSize = n-i-1;
    RealScalar beta;
    Scalar h;
    matA.col(i).tail(remainingSize).makeHouseholderInPlace(h, beta);
    matA.col(i).coeffRef(i+1) = beta;
