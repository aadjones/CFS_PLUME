 ) : (void)0)
# 405 "../../src/Eigen/Eigen/src/Eigenvalues/RealSchur.h"
                 ;
  
# 406 "../../src/Eigen/Eigen/src/Eigenvalues/RealSchur.h" 3 4
 (__builtin_expect(!(
# 406 "../../src/Eigen/Eigen/src/Eigenvalues/RealSchur.h"
 im <= iu-2
# 406 "../../src/Eigen/Eigen/src/Eigenvalues/RealSchur.h" 3 4
 ), 0) ? __assert_rtn(__func__, "RealSchur.h", 406, 
# 406 "../../src/Eigen/Eigen/src/Eigenvalues/RealSchur.h"
