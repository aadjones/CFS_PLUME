  void clear();



  void write(const string& filename) { write(filename.c_str()); };
  void write(const char* filename);
  void write(FILE* file);




  bool read(const char* filename);
  void read(FILE* file);


  void resizeAndWipe(int size);


  VECTOR& operator=(const VECTOR& m);
  VECTOR& operator=(vector<double> m);
  VECTOR& operator=(const double& m);
  VECTOR& operator=(const float& m);
  VECTOR& operator=(const int& m);
  VECTOR& operator+=(const VECTOR& v);
  VECTOR& operator-=(const VECTOR& v);
  VECTOR& operator*=(const double& alpha);


  double norm2() const;


  double operator*(const VECTOR& vector) const;


  double* data() { return _vector; };
  const double* dataConst() const { return _vector; };


  void axpy(double alpha, const VECTOR& x);


  VECTOR abs() const;


  double min() const;


  double max() const;

  static bool printVertical;

private:
  int _size;
  int _sseSize;
  double* _vector;
};




inline ostream &operator<<(ostream &out, VECTOR vector)
{
  out << "[";
  if (VECTOR::printVertical)
  {
    out << endl;
    for (int x = 0; x < vector.size(); x++)
      out << vector(x) << endl;
  }
  else
    for (int x = 0; x < vector.size(); x++)
      out << vector(x) << " ";
  out << "]";
  if (VECTOR::printVertical)
    out << endl;
  return out;
}


VECTOR operator-(const VECTOR& x, const VECTOR& y);
VECTOR operator+(const VECTOR& x, const VECTOR& y);
VECTOR operator*(const VECTOR& x, const double& scalar);
VECTOR operator*(const double& scalar, const VECTOR& x);


double operator^(const VECTOR& x, const VECTOR& y);
