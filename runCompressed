#!/bin/bash
set -e

CFG=${1:-cfg/stam.64.cfg}

if [ ! -f "$CFG" ]; then
    echo "Error: Config file not found: $CFG"
    exit 1
fi

if [ ! -f "./bin/reducedCompressed3D" ]; then
    echo "Error: ./bin/reducedCompressed3D not found. Run 'make' first."
    exit 1
fi

# Create output directories referenced by config
COMPRESSION_PATH=$(grep "^compression path" "$CFG" | cut -d'=' -f2 | tr -d ' ')
if [ -n "$COMPRESSION_PATH" ]; then
    mkdir -p "$COMPRESSION_PATH"
    mkdir -p "${COMPRESSION_PATH}pbrt"
fi
mkdir -p ./movies

echo "Using config file: $CFG"
./bin/reducedCompressed3D "$CFG"
